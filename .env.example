# — Copy to .env.local and fill in. Never commit secrets.

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Anthropic — list models: GET https://api.anthropic.com/v1/models
ANTHROPIC_API_KEY=""
# Current Sonnet recommended ID (see Models overview in Anthropic docs)
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Cloudflare Turnstile (optional in dev if secret unset server-side)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Upstash Redis (optional — without it, rate limiting is disabled with a console warning)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Supabase (optional — server-side logging of assessment events)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
